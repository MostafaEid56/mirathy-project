# PostgreSQL
DB_URL=jdbc:postgresql://your-host:5432/mirathy
DB_USERNAME=neondb_owner
DB_PASSWORD=your_new_secure_password

# JWT Security
JWT_SECRET=your_new_super_secure_jwt_secret_key_needs_to_be_long_enough
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:80,https://mirathy.example.com

# Email Settings
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_new_gmail_app_password

# Frontend URL for activation logic
ACTIVATION_URL=https://mirathy.example.com/activate-account
